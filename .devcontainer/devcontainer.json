{
  "name": "Rust",
  "runArgs": [
    "--sysctl",
    "net.ipv6.conf.all.disable_ipv6=1",
    "--cap-add=NET_ADMIN",
    "--device=/dev/net/tun"
  ],
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "upgradePackages": true,
      "username": "vscode"
    },
    "ghcr.io/devcontainers-extra/features/apt-packages:1": {
      "packages": "socat"
    },
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "mounts": [
    "source=stripe-toddler-wrangler-config,target=/home/vscode/.wrangler,type=volume",
    "source=stripe-toddler-doppler-config,target=/home/vscode/.doppler,type=volume",
    "source=gemini-cli-settings,target=/home/vscode/.gemini,type=volume",
    "source=stripe-toddler-tailscale-state,target=/var/lib/tailscale,type=volume"
  ],
  "forwardPorts": [
    8788,
    8976,
    36079,
    33301,
    37677
  ],
  "containerEnv": {
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8"
  },
  "postCreateCommand": ".devcontainer/post-create-setup.sh",
  "postStartCommand": "bash /workspaces/stripe-toddler/.devcontainer/post-start-setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "pcassidy75.tmux-integrated",
        "vsc-mermaid.mermaid-preview",
        "saoudrizwan.claude-dev",
        "GitHub.copilot",
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates",
        "doppler.doppler-vscode",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "svelte.svelte-vscode",
        "usernamehw.errorlens",
        "streetsidesoftware.code-spell-checker",
        "eamodio.gitlens",
        "donjayamanne.githistory",
        "mhutchie.git-graph",
        "redhat.vscode-yaml",
        "bierner.markdown-mermaid",
        "pomdtr.excalidraw-editor",
        "pejmannikram.vscode-auto-scroll",
        "naumovs.color-highlight",
        "oderwat.indent-rainbow",
        "wix.vscode-import-cost",
        "mkxml.vscode-filesize",
        "christian-kohler.npm-intellisense",
        "GitHub.vscode-pull-request-github",
        "shyykoserhiy.git-autoconfig",
        "actboy168.tasks",
        "humao.rest-client",
        "alefragnani.project-manager",
        "mutantdino.resourcemonitor"
      ]
    }
  }
}